rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsResource() {
      return signedIn() && resource.data.uid == request.auth.uid;
    }

    function ownsIncoming() {
      return signedIn() && request.resource.data.uid == request.auth.uid;
    }

    function ownsPost(postId) {
      return signedIn()
        && get(/databases/$(database)/documents/posts/$(postId)).data.uid == request.auth.uid;
    }

    match /posts/{postId} {
      allow read: if signedIn();
      allow create: if ownsIncoming();
      allow update: if (ownsResource()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['description', 'location', 'city', 'state', 'updatedAt']))
        || (signedIn()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['commentsCount'])
          && request.resource.data.commentsCount is int
          && request.resource.data.commentsCount >= 0
          && (
            request.resource.data.commentsCount == resource.data.commentsCount + 1
            || request.resource.data.commentsCount == resource.data.commentsCount - 1
          ));
      allow delete: if ownsResource();
    }

    match /comments/{commentId} {
      allow read: if signedIn();
      allow create: if ownsIncoming();
      allow update: if ownsResource();
      allow delete: if ownsResource() || ownsPost(resource.data.postId);
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update, delete: if signedIn() && userId == request.auth.uid;
    }

    match /captures/{captureId} {
      allow read: if signedIn();
      allow create: if ownsIncoming();
      allow update: if ownsResource()
        || (signedIn()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes'])
          && request.resource.data.likes is int);
      allow delete: if ownsResource();
    }

    match /{document=**} {
      allow read: if signedIn();
      allow write: if false;
    }
  }
}
